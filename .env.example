# ============================================================================
# Environment variables for PPI Monash Malaysia
# ============================================================================
# Copy this file to ".env" and fill in real values. Only variables prefixed
# with VITE_ are exposed to the client bundle (Vite convention).
#
# Analytics is OPT-IN: if VITE_PLAUSIBLE_DOMAIN is left blank, no analytics
# script loads and no requests are made. This keeps local dev clean and keeps
# the Privacy Policy accurate until you intentionally enable tracking.

# Cookieless analytics (Plausible / GoatCounter / Umami compatible).
# Set this to the domain registered in your analytics dashboard to enable it.
VITE_PLAUSIBLE_DOMAIN=

# (Optional) Override the analytics script URL. Defaults to Plausible's
# manual-pageview script. Examples:
#   Plausible cloud:  https://plausible.io/js/script.manual.js
#   Self-hosted:      https://analytics.yourdomain.com/js/script.manual.js
# VITE_PLAUSIBLE_SRC=https://plausible.io/js/script.manual.js
