# ============================================================================
# Environment variables for PPI Monash Malaysia
# ============================================================================
# Copy this file to ".env" and fill in real values. Only variables prefixed
# with VITE_ are exposed to the client bundle (Vite convention).

# Google Analytics 4 measurement ID (looks like G-XXXXXXXXXX).
# Analytics is OPT-IN and cookie-consented:
#   - Leave this blank  -> no analytics loads, no consent banner shows.
#   - Set it            -> a cookie-consent banner appears; GA only loads and
#                          tracks AFTER the visitor clicks "Accept".
VITE_GA_MEASUREMENT_ID=
